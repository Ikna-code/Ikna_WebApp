generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id
  email         String         @unique
  role          Role           @default(USER)
  firstName     String?        @map("first_name")
  lastName      String?        @map("last_name")
  phone         String?
  addresses     Address[]
  cartItems     CartItem[]
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@map("User")
}

model Address {
  id        String   @id @default(cuid())
  userId    String   @map("userId")
  name      String
  street    String
  city      String
  state     String
  zip       String
  country   String   @default("India")
  isDefault Boolean  @default(false) @map("isDefault")
  createdAt DateTime @default(now()) @map("createdAt")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@map("addresses")
}

model ProductType {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  description   String?
  icon          String?
  displayOrder  Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  products      Product[]
  comboPacks    ComboPack[]
  filterGroups  FilterGroup[]
  subcategories SubCategory[]

  @@index([slug])
  @@map("product_types")
}

model SubCategory {
  id            String      @id @default(cuid())
  productTypeId String
  name          String
  slug          String
  description   String?
  displayOrder  Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  products      Product[]
  productType   ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)

  @@unique([productTypeId, slug])
  @@index([productTypeId])
  @@map("sub_categories")
}

model Product {
  id                 String               @id @default(cuid())
  name               String
  price              Decimal              @db.Decimal(10, 2)
  description        String
  image              String
  stock              Int                  @default(0)
  createdAt          DateTime             @default(now()) @db.Timestamp(0)
  updatedAt          DateTime             @updatedAt
  tag                String?
  rating             Float?
  sizes              String[]             @default([])
  colorHex           String?              @default("#000000")
  colorName          String?              @default("Unspecified")
  productTypeId      String
  subCategoryId      String?
  category           String?
  productType        ProductType          @relation(fields: [productTypeId], references: [id])
  subCategory        SubCategory?         @relation(fields: [subCategoryId], references: [id])
  ComboPackToProduct ComboPackToProduct[]
  ComboProducts      ComboProducts[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  filters            ProductFilter[]
  images             ProductImage[]
  reviews            Review[]
  wishlistItems      WishlistItem[]

  @@index([productTypeId])
  @@index([subCategoryId])
  @@map("Product")
}

model FilterGroup {
  id            String         @id @default(cuid())
  productTypeId String
  name          String
  displayName   String
  slug          String
  displayOrder  Int            @default(0)
  isActive      Boolean        @default(true)
  filterType    FilterType     @default(MULTI_SELECT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  productType   ProductType    @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  filterOptions FilterOption[]

  @@unique([productTypeId, slug])
  @@index([productTypeId])
  @@map("filter_groups")
}

model FilterOption {
  id             String          @id @default(cuid())
  filterGroupId  String
  value          String
  displayLabel   String
  colorHex       String?
  displayOrder   Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  filterGroup    FilterGroup     @relation(fields: [filterGroupId], references: [id], onDelete: Cascade)
  productFilters ProductFilter[]

  @@index([filterGroupId])
  @@map("filter_options")
}

model ProductFilter {
  id             String       @id @default(cuid())
  productId      String
  filterOptionId String
  filterOption   FilterOption @relation(fields: [filterOptionId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, filterOptionId])
  @@index([productId])
  @@index([filterOptionId])
  @@map("product_filters")
}

model ProductImage {
  id         String   @id @default(cuid())
  product_id String
  image_path String
  is_primary Boolean? @default(false)
  public_id  String?
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model CartItem {
  id           String  @id @default(cuid())
  userId       String  @map("userId")
  productId    String  @map("productId")
  quantity     Int     @default(1)
  comboEligibleQuantity Int @default(0)
  comboBundleId String @default("")
  selectedSize String?
  category     String?
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, selectedSize, comboBundleId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model Order {
  id                String      @id @default(cuid())
  userId            String
  totalAmount       Decimal     @db.Decimal(10, 2)
  status            OrderStatus @default(PENDING)
  createdAt         DateTime    @default(now())
  addressId         String?
  shippingAddress   String?
  couponAppliedId   String?
  discountAmount    Decimal     @default(0.00) @db.Decimal(10, 2)
  isFirstOrder      Boolean     @default(false)
  paidAt            DateTime?
  packedAt          DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  razorpayOrderId   String?     @unique
  shiprocketOrderId String?
  shipmentId        String?
  awbCode           String?
  courierName       String?
  trackingUrl       String?
  shiprocketStatus  String?
  orderItems        OrderItem[]
  address           Address?    @relation(fields: [addressId], references: [id])
  coupon            Coupon?     @relation(fields: [couponAppliedId], references: [id])
  user              User        @relation(fields: [userId], references: [id])
  payment           Payment?

  @@index([shiprocketOrderId])
  @@index([shipmentId])
  @@map("orders")
}

model OrderItem {
  id              String           @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  price           Decimal          @db.Decimal(10, 2)
  selectedSize    String?
  comboOfferId    String?
  orderComboItems OrderComboItem[]
  comboOffer      ComboOffer?      @relation(fields: [comboOfferId], references: [id])
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus
  provider      String
  transactionId String?       @unique
  createdAt     DateTime      @default(now())
  order         Order         @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Coupon {
  id           String       @id @default(cuid())
  code         String       @unique
  discountType DiscountType @default(PERCENTAGE)
  value        Decimal      @db.Decimal(10, 2)
  minSubtotal  Decimal      @default(0.00) @db.Decimal(10, 2)
  isActive     Boolean      @default(true)
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())
  orders       Order[]

  @@map("coupons")
}

model ComboOffer {
  id            String          @id @default(cuid())
  name          String
  discountPct   Float
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  ComboProducts ComboProducts[]
  orderItems    OrderItem[]

  @@map("combo_offers")
}

model ComboPack {
  id                 String               @id @default(cuid())
  name               String
  description        String?
  productTypeId      String
  minQuantity        Int                  @default(3)
  maxQuantity        Int?
  discountType       DiscountType         @default(PERCENTAGE)
  discountValue      Decimal              @db.Decimal(10, 2)
  isActive           Boolean              @default(true)
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  ComboPackToProduct ComboPackToProduct[]
  productType        ProductType          @relation(fields: [productTypeId], references: [id])
  orderComboItems    OrderComboItem[]

  @@index([productTypeId])
  @@map("combo_packs")
}

model OrderComboItem {
  id              String    @id @default(cuid())
  orderItemId     String
  comboPackId     String
  quantityInCombo Int
  discountApplied Decimal   @db.Decimal(10, 2)
  comboPack       ComboPack @relation(fields: [comboPackId], references: [id])
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([comboPackId])
  @@map("order_combo_items")
}

model Review {
  id            String        @id @default(cuid())
  rating        Int           @default(5)
  title         String?
  comment       String
  isVerified    Boolean       @default(false)
  helpful       Int           @default(0)
  fitExperience String?
  createdAt     DateTime      @default(now())
  userId        String
  productId     String
  images        ReviewImage[]
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model ReviewImage {
  id       String @id @default(cuid())
  url      String
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
}

model ComboProducts {
  A            String
  B            String
  combo_offers ComboOffer @relation(fields: [A], references: [id], onDelete: Cascade)
  Product      Product    @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_ComboProducts_AB_unique")
  @@index([B], map: "_ComboProducts_B_index")
  @@map("_ComboProducts")
}

model ComboPackToProduct {
  A           String
  B           String
  combo_packs ComboPack @relation(fields: [A], references: [id], onDelete: Cascade)
  Product     Product   @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_ComboPackToProduct_AB_unique")
  @@index([B], map: "_ComboPackToProduct_B_index")
  @@map("_ComboPackToProduct")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
  DELIVERED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum FilterType {
  MULTI_SELECT
  SINGLE_SELECT
  RANGE
  COLOR
}
